# EduTrack Spring Boot Backend Environment Configuration
# Copy this file to .env and replace with your actual values

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/edutrack?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=root

# Security Configurations
JWT_SECRET=super_secret_jwt_key_that_is_long_enough_for_hmac256_2026_spring_boot
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Email Configuration
MAIL_USER=hello@edutrack.com
MAIL_PASS=application_specific_password
